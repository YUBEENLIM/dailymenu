{
  "permissions": {
    "allow": [
      "Bash(./gradlew compileJava)",
      "Bash(./gradlew compileJava compileTestJava)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew dependencies:*)",
      "Bash(curl -s \"https://search.maven.org/solrsearch/select?q=g:org.springdoc+AND+a:springdoc-openapi-starter-webmvc-ui&rows=5&core=gav&wt=json\")",
      "Bash(python3 -c \"import sys,json; docs=json.load\\(sys.stdin\\)['response']['docs']; [print\\(d['v']\\) for d in docs]\")",
      "Bash(curl:*)",
      "Bash(docker exec dailymenu-mysql:*)",
      "Bash(./gradlew bootRun)",
      "Bash(echo \"PID=$!\")",
      "Bash(docker exec:*)",
      "Bash(cat /c/intelliJCommunityProjects/dailymenu/src/main/resources/application*.yml)",
      "Bash(grep -r \"hikari\\\\|datasource\\\\|connection\" /c/intelliJCommunityProjects/dailymenu/src/main/resources/application*.yml)",
      "Bash(xargs grep:*)",
      "Bash(grep:*)",
      "WebFetch(domain:github.com)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "dev-logs/ 에서 가장 최근 파일을 읽고 미완료 항목이 있으면 간단히 알려줘. 없으면 아무 말도 하지 마.",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "dev-logs/YYYY-Www.md (예: 2026-W16.md) 파일에 오늘 작업을 기록해라. 파일이 있으면 기존 내용 유지하고 추가, 없으면 새로 생성. 형식: ## MM/DD 아래에 - 완료: 항목 / - 미완료: 항목. 팩트만 간결하게.",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
